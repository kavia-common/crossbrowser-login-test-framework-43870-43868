{
  "name": "react-kavia",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "react-scripts": "^5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:e2e": "npx playwright test",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:firefox": "npx playwright test --project=firefox",
    "test:e2e:webkit": "npx playwright test --project=webkit",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:heroku": "npx playwright test heroku-login",
    "test:e2e:practice": "npx playwright test practice-test-login",
    "test:e2e:saucedemo": "npx playwright test saucedemo-login",
    "test:e2e:expanded": "npx playwright test --grep 'Expanded'",
    "test:e2e:heroku:expanded": "npx playwright test heroku-login-expanded",
    "test:e2e:practice:expanded": "npx playwright test practice-test-login-expanded",
    "test:e2e:saucedemo:expanded": "npx playwright test saucedemo-login-expanded",
    "test:e2e:report": "npx playwright show-report playwright-report",
    "test:e2e:all-browsers": "npx playwright test --project=chromium --project=firefox --project=webkit"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^7.0.3"
  }
}
